# AGOS Server
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/agos
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Production overrides (example)
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/agos
# CLIENT_URL=https://agos.yourdomain.com
# JWT_SECRET=use-a-32-char-random-string-here
